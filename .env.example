# MySQL / MariaDB 连接串（本地 docker-compose 默认映射到 3308；Plesk 通常是 3306）
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://repairnote:repairnote@127.0.0.1:3308/repairnote"
REPAIRNOTE_ADMIN_USERNAME="admin"
# 首次安装临时密码。安装后请到系统里改成自己的强密码。
REPAIRNOTE_ADMIN_PASSWORD="admin123"
REPAIRNOTE_COOKIE_SECURE=false
